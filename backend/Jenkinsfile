pipeline {
    agent any

    environment {
        IMAGE_NAME = "easyflow-backend:${env.BUILD_NUMBER}"
    }

    stages {
        stage('Cleanup & Checkout') {
            steps {
                // ใช้ Docker (สิทธิ์ Root) ล้าง node_modules ใน workspace ปัจจุบันก่อนเริ่ม
                sh 'docker run --rm -v ${WORKSPACE}:/ws -w /ws alpine rm -rf backend/node_modules'
                checkout scm
            }
        }

        stage('Install & Test') {
            steps {
                // รันคำสั่งภายใน Container โดยใช้ Workspace เดียวกับ Host
                script {
                    docker.image('node:18-alpine').inside('-u root:root') {
                        dir('backend') {
                            sh '''
                                if [ -f package-lock.json ]; then
                                    npm ci
                                else
                                    npm install
                                fi

                                if [ -f prisma/schema.prisma ]; then
                                    npx prisma generate || true
                                fi

                                npm test || echo "Tests failed but moving on..."
                            '''
                        }
                    }
                }
            }
        }

        stage('Docker Build') {
            steps {
                dir('backend') {
                    sh "docker build -t ${IMAGE_NAME} ."
                }
            }
        }

        stage('Deploy') {
            steps {
                sh """
                    docker stop easyflow-backend || true
                    docker rm easyflow-backend || true
                    docker run -d --name easyflow-backend -p 9000:9000 \
                        --link postgres-db:postgres \
                        -e DATABASE_URL="postgresql://postgres:root@10.240.68.201:5432/postgres?schema=public" \
                        ${IMAGE_NAME}
                """
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'backend/*.log', allowEmptyArchive: true
        }
    }
}