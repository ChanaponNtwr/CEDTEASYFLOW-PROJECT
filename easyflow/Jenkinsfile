pipeline {
  agent any

  environment {
    IMAGE_NAME = "easyflow-frontend:${env.BUILD_NUMBER}"
    # เปลี่ยนเวอร์ชันนี้ถ้าคุณต้องการใช้ Prisma เวอร์ชันอื่นที่ทดสอบแล้ว
    PRISMA_PIN_VERSION = "5.7.1"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install & Test & Build (node)') {
      agent {
        docker {
          image 'node:18-bullseye'
          args '-u root:root -e BASE_API=${BASE_API}'
        }
      }
      steps {
        dir('easyflow') {
          sh '''
            set -e
            echo "=== SETUP SCHEMA FROM BACKEND ==="
            mkdir -p prisma
            cp ../backend/prisma/schema.prisma ./prisma/schema.prisma || true

            echo "=== PIN PRISMA (fix broken CLI versions) ==="
            # ติดตั้ง/อัปเดต Prisma และ @prisma/client ให้เป็นเวอร์ชันที่กำหนดไว้
            # จะอัปเดต package.json และ package-lock.json
            npm install prisma@${PRISMA_PIN_VERSION} --save-dev @prisma/client@${PRISMA_PIN_VERSION} --save

            echo "=== CLEAN OLD ==="
            rm -rf node_modules
            rm -rf .prisma
            rm -rf node_modules/.prisma

            echo "=== INSTALL DEPENDENCIES (reproducible) ==="
            # ถ้ามี package-lock.json แล้ว npm ci จะติดตั้งตาม lockfile ที่อัปเดต
            npm ci

            echo "=== DEBUG VERSIONS ==="
            node -v
            npm -v
            echo "Installed prisma in node_modules:"
            npm list prisma --depth=0 || true
            echo "npx prisma --version (primary check)"

            # ถ้า npx prisma --version fail ให้ลองเรียกเฉพาะเวอร์ชันที่ pinned เป็น fallback
            if ! npx prisma --version; then
              echo "npx prisma failed; trying pinned version directly"
              npx prisma@${PRISMA_PIN_VERSION} --version || {
                echo "ERROR: Prisma CLI still failing after pinning to ${PRISMA_PIN_VERSION}"
                echo "List node_modules/.prisma (if exists):"
                ls -la node_modules/.prisma || true
                exit 1
              }
            fi

            echo "=== PRISMA GENERATE ==="
            export PRISMA_CLI_QUERY_ENGINE_TYPE=binary
            export PRISMA_CLIENT_ENGINE_TYPE=binary
            export NODE_OPTIONS="--stack-size=60000 --max-old-space-size=4096"
            # เพิ่ม OS stack (ถ้าไม่สำเร็จไม่ fail)
            ulimit -s 65535 || true

            npx prisma generate --schema=./prisma/schema.prisma

            echo "=== TEST (continue on fail) ==="
            npm test || true

            echo "=== BUILD ==="
            echo "Checking BASE_API: $BASE_API"
            npm run build
          '''
        }
      }
    }

    stage('Build Docker Image') {
      steps {
        sh '''
          docker build \
            -t easyflow-frontend:${BUILD_NUMBER} \
            -f easyflow/Dockerfile \
            .
          docker tag easyflow-frontend:${BUILD_NUMBER} easyflow-frontend:latest
        '''
      }
    }

    stage('Deploy (local docker)') {
      steps {
        sh '''
          docker stop easyflow-frontend || true
          docker rm easyflow-frontend || true

          docker run -d \
            --name easyflow-frontend \
            -p 3000:3000 \
            --link postgres-db:postgres \
            --link easyflow-backend:backend \
            -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \
            -e BASE_API="http://easyflow-backend:9000" \
            -e NEXTAUTH_URL="http://localhost:3000" \
            -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \
            -e SERVER_HOST="0.0.0.0" \
            -e GOOGLE_CLIENT_ID="" \
            -e GOOGLE_CLIENT_SECRET="" \
            easyflow-frontend:latest
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'easyflow/.next/**', allowEmptyArchive: true
      cleanWs()
    }
  }
}
