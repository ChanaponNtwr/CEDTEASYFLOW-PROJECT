pipeline {
    agent any

    environment {
        IMAGE_NAME = "easyflow-frontend"
        TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Prepare & Build Context') {
            agent {
                docker {
                    image 'node:20-alpine'
                    // ใช้ root เพื่อจัดการไฟล์ แต่ต้องระวังเรื่อง permission ตอนจบ
                    args '-u root:root' 
                }
            }
            steps {
                dir('easyflow') {
                    sh '''
                        echo "=== 1. PREPARE SCHEMA ==="
                        mkdir -p prisma
                        
                        # Copy schema จาก backend (ตรวจสอบ path ให้แน่ใจว่าถูกต้อง)
                        cp ../backend/prisma/schema.prisma ./prisma/schema.prisma
                        
                        echo "=== 2. INSTALL & GENERATE ==="
                        # ลบของเก่าเพื่อความสะอาด
                        rm -rf node_modules
                        
                        npm ci
                        npx prisma generate
                        
                        # [FIX] แก้ Permission ให้ user ภายนอก (Jenkins) อ่าน/เขียนได้
                        # ป้องกันปัญหา Permission Denied ตอน Build stage
                        chmod -R 777 prisma
                        chmod -R 777 node_modules
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('easyflow') {
                    sh """
                        echo "=== DOCKER BUILD SETUP ==="
                        
                        # [FIX] ตรวจสอบว่า folder มีอยู่จริง
                        ls -la prisma || echo "WARNING: prisma folder missing"
                        
                        # [FIX] บังคับแก้ไข .dockerignore เพื่อไม่ให้ข้าม prisma
                        # ถ้าไฟล์ .dockerignore มีอยู่ ให้เพิ่มกฎ whitelist
                        if [ -f .dockerignore ]; then
                            echo "Found .dockerignore, appending !prisma rule..."
                            echo "!prisma" >> .dockerignore
                            echo "!node_modules" >> .dockerignore
                        fi

                        echo "=== START BUILD ==="
                        docker build -t ${IMAGE_NAME}:${TAG} .
                        docker tag ${IMAGE_NAME}:${TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy (local docker)') {
            steps {
                sh """
                    docker stop ${IMAGE_NAME} || true
                    docker rm ${IMAGE_NAME} || true
                    
                    docker run -d \\
                        --name ${IMAGE_NAME} \\
                        --restart unless-stopped \\
                        -p 3000:3000 \\
                        --link postgres-db:postgres \\
                        --link easyflow-backend:backend \\
                        -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
                        -e BASE_API="http://easyflow-backend:9000" \\
                        -e NEXTAUTH_URL="http://localhost:3000" \\
                        -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
                        -e SERVER_HOST="0.0.0.0" \\
                        ${IMAGE_NAME}:latest
                """
            }
        }
    }

    post {
        always {
            script {
                try {
                     // ใช้ Docker ช่วยลบไฟล์ที่สร้างโดย root
                     sh 'docker run --rm -v "${WORKSPACE}:/app" -w /app alpine rm -rf *'
                } catch (err) {
                     echo "Failed to clean via docker, trying standard clean..."
                     cleanWs()
                }
            }
        }
    }
}