pipeline {
  agent any
  environment {
    NODE_VERSION = '20' // ค่าที่ต้องการ
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Env Check') {
      steps {
        sh '''
          echo "=== ENV CHECK ==="
          node -v || true
          npm -v || true
          uname -a || true
          cat /etc/os-release || true
        '''
      }
    }

    stage('Prepare') {
      steps {
        sh '''
          echo "=== CLEAN & PREPARE ==="
          rm -rf node_modules .prisma
          rm -f package-lock.json
        '''
      }
    }

    stage('Install') {
      steps {
        sh '''
          echo "=== INSTALL DEPENDENCIES ==="
          npm ci
        '''
      }
    }

    stage('Generate Prisma') {
      steps {
        sh '''
          echo "=== PRISMA GENERATE ==="
          # คัดลอก schema ถ้าจำเป็น (ปรับเส้นทางให้ตรงกับ repo)
          mkdir -p prisma
          if [ -f backend/prisma/schema.prisma ]; then cp backend/prisma/schema.prisma prisma/schema.prisma; fi

          # เรียกผ่าน npx เพื่อหลีกเลี่ยงการเรียก binary โดยตรง
          npx prisma generate --schema=./prisma/schema.prisma
        '''
      }
    }

    stage('Build') {
      steps {
        sh '''
          echo "=== BUILD ==="
          # ตัวอย่าง: ถ้าใช้ Next.js
          # npm run build
        '''
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'prisma/**', allowEmptyArchive: true
      echo 'Pipeline finished'
    }
  }
}
