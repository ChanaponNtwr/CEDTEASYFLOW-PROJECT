pipeline {
    agent any

    environment {
        IMAGE_NAME = "easyflow-frontend"
        TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        // ยุบรวมขั้นตอนเตรียมไฟล์ + Install ไว้ใน Docker ที่เป็น Root
        stage('Prepare & Build Context') {
            agent {
                docker {
                    image 'node:20-alpine'
                    // ใช้ root user เพื่อให้มีสิทธิ์เขียนไฟล์ทับได้แน่นอน
                    args '-u root:root' 
                }
            }
            steps {
                dir('easyflow') {
                    sh '''
                        echo "=== 1. PREPARE SCHEMA ==="
                        # สร้าง folder (ถ้ายังไม่มี)
                        mkdir -p prisma
                        
                        # [Fix] ตรวจสอบว่าไฟล์ต้นทางมีอยู่จริงหรือไม่ ก่อน Copy
                        if [ ! -f ../backend/prisma/schema.prisma ]; then
                            echo "ERROR: Backend schema not found at ../backend/prisma/schema.prisma"
                            echo "Please check if the backend repository is checked out or the path is correct."
                            exit 1
                        fi

                        # Copy ไฟล์จาก backend
                        cp ../backend/prisma/schema.prisma ./prisma/schema.prisma
                        
                        echo "=== 2. INSTALL & GENERATE ==="
                        # ลบ node_modules เก่าทิ้งก่อน เพื่อความชัวร์
                        rm -rf node_modules
                        
                        npm ci
                        npx prisma generate
                    '''
                }
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('easyflow') {
                    sh """
                        echo "=== DEBUG: FIX PERMISSIONS & CHECK FILES ==="
                        
                        # [Fix] ย้าย chmod มาก่อนการตรวจสอบไฟล์ เพื่อให้มั่นใจว่า ls อ่านไฟล์ได้
                        # Fix permissions: Ensure current user owns the files created by root
                        sudo chown -R \$(id -u):\$(id -g) . || true

                        # Debug: Check existence specifically
                        ls -la prisma || echo "Prisma folder missing!"

                        echo "=== DOCKER BUILD ==="
                        docker build -t ${IMAGE_NAME}:${TAG} .
                        docker tag ${IMAGE_NAME}:${TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy (local docker)') {
            steps {
                sh """
                    docker stop ${IMAGE_NAME} || true
                    docker rm ${IMAGE_NAME} || true
                    
                    docker run -d \\
                        --name ${IMAGE_NAME} \\
                        --restart unless-stopped \\
                        -p 3000:3000 \\
                        --link postgres-db:postgres \\
                        --link easyflow-backend:backend \\
                        -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
                        -e BASE_API="http://easyflow-backend:9000" \\
                        -e NEXTAUTH_URL="http://localhost:3000" \\
                        -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
                        -e SERVER_HOST="0.0.0.0" \\
                        ${IMAGE_NAME}:latest
                """
            }
        }
    }

    post {
        always {
            script {
                try {
                     // ใช้ Docker ช่วยลบไฟล์ root
                     sh 'docker run --rm -v "${WORKSPACE}:/app" -w /app alpine rm -rf *'
                } catch (err) {
                     echo "Failed to clean via docker, trying standard clean..."
                     cleanWs()
                }
            }
        }
    }
}