pipeline {
  agent any
  environment {
    IMAGE_NAME = "easyflow-frontend:${env.BUILD_NUMBER}"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install & Test & Build (node)') {
      agent {
        docker {
          image 'node:18' 
          // เพิ่ม -e NODE_ENV=development เพื่อบังคับให้ install devDependencies (Prisma CLI) เสมอ
          args '-u root:root -e BASE_API=${BASE_API} -e NODE_ENV=development'
        }
      }
      steps {
        dir('easyflow') {
          sh '''
             # 1. ติดตั้ง Library พื้นฐานที่จำเป็น (OpenSSL)
             apt-get update -y && apt-get install -y openssl

             # 2. เตรียม Schema
             echo "=== SETUP SCHEMA FROM BACKEND ==="
             mkdir -p prisma
             cp ../backend/prisma/schema.prisma ./prisma/schema.prisma

             # 3. Clean & Install แบบล้างบาง
             echo "=== CLEAN & INSTALL ==="
             rm -rf node_modules
             rm -rf .prisma
             rm -rf node_modules/.prisma
             
             # ลบ package-lock.json เพื่อแก้ปัญหา version ตีกัน
             rm -f package-lock.json
             
             # ย้ำอีกครั้งว่าต้องเป็น development เพื่อให้ได้ prisma cli
             export NODE_ENV=development
             npm install

             echo "=== GENERATE & BUILD ==="
             
             # Debug: เช็คว่า prisma cli ถูกติดตั้งจริงไหม (Log ต้องเจอไฟล์)
             ls -l ./node_modules/.bin/prisma || echo "Prisma Binary NOT FOUND"
             
             # --- จุดสำคัญ (FIX) ---
             # เรียกใช้ Prisma จาก node_modules โดยตรง (ห้ามใช้ npx prisma เฉยๆ)
             # เพื่อป้องกันมันไปโหลด version ล่าสุดมาใช้จนเกิด Stack Overflow
             ./node_modules/.bin/prisma generate --schema=./prisma/schema.prisma
             # ---------------------

             npm test || true
             
             echo "Checking BASE_API: $BASE_API"
             
             # Build โปรเจกต์ (Next.js จะจัดการ env production ให้เองตอน build)
             npm run build
          '''
        }
      }
    }
    
    stage('Build Docker Image') {
      steps {
        sh '''
          docker build \
            -t easyflow-frontend:${BUILD_NUMBER} \
            -f easyflow/Dockerfile \
            .
          docker tag easyflow-frontend:${BUILD_NUMBER} easyflow-frontend:latest
        '''
      }
    }

    stage('Deploy (local docker)') {
      steps {
        sh """
          docker stop easyflow-frontend || true
          docker rm easyflow-frontend || true
          
          docker run -d \\
            --name easyflow-frontend \\
            -p 3000:3000 \\
            --link postgres-db:postgres \\
            --link easyflow-backend:backend \\
            -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
            -e BASE_API="http://easyflow-backend:9000" \\
            -e NEXTAUTH_URL="http://localhost:3000" \\
            -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
            -e SERVER_HOST="0.0.0.0" \\
            -e GOOGLE_CLIENT_ID="your-real-id-or-leave-empty-if-not-used" \\
            -e GOOGLE_CLIENT_SECRET="your-real-secret-or-leave-empty-if-not-used" \\
            easyflow-frontend:latest
        """
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'easyflow/.next/**', allowEmptyArchive: true
    }
  }
}