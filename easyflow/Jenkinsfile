pipeline {
    agent any

    environment {
        IMAGE_NAME = "easyflow-frontend"
        TAG = "${env.BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build Docker Image') {
            steps {
                dir('easyflow') {
                    sh """
                        echo "=== 1. PREPARE PRISMA SCHEMA ==="
                        # สร้าง folder prisma รอไว้
                        mkdir -p prisma

                        # ตรวจสอบว่ามีไฟล์จาก backend จริงไหม
                        if [ -f ../backend/prisma/schema.prisma ]; then
                            echo "Found backend schema, copying..."
                            cp ../backend/prisma/schema.prisma ./prisma/schema.prisma
                        else
                            echo "WARNING: Backend schema not found at ../backend/prisma/schema.prisma"
                            echo "Build might fail if schema is required."
                            ls -la .. || true
                        fi

                        echo "=== 2. CHECK FILES ==="
                        ls -la prisma

                        echo "=== 3. DOCKER BUILD ==="
                        # Build Image (ใช้ Dockerfile ตัวใหม่ที่เป็น node:20-slim)
                        docker build -t ${IMAGE_NAME}:${TAG} .
                        docker tag ${IMAGE_NAME}:${TAG} ${IMAGE_NAME}:latest
                    """
                }
            }
        }

        stage('Deploy (local docker)') {
            steps {
                sh """
                    echo "=== DEPLOYING ==="
                    docker stop ${IMAGE_NAME} || true
                    docker rm ${IMAGE_NAME} || true
                    
                    docker run -d \\
                        --name ${IMAGE_NAME} \\
                        --restart unless-stopped \\
                        -p 3000:3000 \\
                        --link postgres-db:postgres \\
                        --link easyflow-backend:backend \\
                        -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
                        -e BASE_API="http://easyflow-backend:9000" \\
                        -e NEXTAUTH_URL="http://localhost:3000" \\
                        -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
                        -e SERVER_HOST="0.0.0.0" \\
                        ${IMAGE_NAME}:latest
                """
            }
        }
    }

    post {
        always {
            script {
                cleanWs()
            }
        }
    }
}