pipeline {
  agent any
  environment {
    IMAGE_NAME = "easyflow-frontend:${env.BUILD_NUMBER}"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install & Test & Build (node)') {
      agent {
        docker {
          image 'node:18' 
          // เพิ่ม Environment Variable เพื่อบังคับใช้ Binary Engine (เสถียรกว่าใน CI)
          args '-u root:root -e BASE_API=${BASE_API} -e PRISMA_CLIENT_ENGINE_TYPE=binary -e PRISMA_CLI_QUERY_ENGINE_TYPE=binary'
        }
      }
      steps {
        dir('easyflow') {
          sh '''
             # 1. ติดตั้ง OpenSSL เพื่อความชัวร์ (บางที Node image ตัวเล็กอาจขาด lib นี้)
             apt-get update -y && apt-get install -y openssl

             # 2. เตรียม Schema
             echo "=== SETUP SCHEMA FROM BACKEND ==="
             mkdir -p prisma
             cp ../backend/prisma/schema.prisma ./prisma/schema.prisma

             # 3. Clean Install
             echo "=== CLEAN & INSTALL ==="
             rm -rf node_modules
             rm -rf .prisma
             rm -rf node_modules/.prisma
             
             # ใช้ npm install แทน npm ci ชั่วคราว เพื่อให้มัน resolve version ที่เข้ากันได้ใหม่หน้างาน
             # (ถ้า npm ci พังบ่อย ท่านี้ช่วยได้แต่ build จะช้าลงนิดหน่อย)
             npm install
             
             # ท่าไม้ตาย: บังคับลง prisma version เดียวกันให้แน่ใจ (แก้ Stack Exceeded)
             # npm install prisma@latest @prisma/client@latest --save-exact

             echo "=== GENERATE & BUILD ==="
             
             # กลับมาใช้คำสั่งปกติ เพราะเราแก้ที่ env var และ dependency แล้ว
             npx prisma generate --schema=./prisma/schema.prisma

             npm test || true
             
             echo "Checking BASE_API: $BASE_API"
             npm run build
          '''
        }
      }
    }
    
    stage('Build Docker Image') {
      steps {
        sh '''
          docker build \
            -t easyflow-frontend:${BUILD_NUMBER} \
            -f easyflow/Dockerfile \
            .
          docker tag easyflow-frontend:${BUILD_NUMBER} easyflow-frontend:latest
        '''
      }
    }

    stage('Deploy (local docker)') {
      steps {
        sh """
          docker stop easyflow-frontend || true
          docker rm easyflow-frontend || true
          
          docker run -d \\
            --name easyflow-frontend \\
            -p 3000:3000 \\
            --link postgres-db:postgres \\
            --link easyflow-backend:backend \\
            -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
            -e BASE_API="http://easyflow-backend:9000" \\
            -e NEXTAUTH_URL="http://localhost:3000" \\
            -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
            -e SERVER_HOST="0.0.0.0" \\
            -e GOOGLE_CLIENT_ID="your-real-id-or-leave-empty-if-not-used" \\
            -e GOOGLE_CLIENT_SECRET="your-real-secret-or-leave-empty-if-not-used" \\
            easyflow-frontend:latest
        """
      }
    }
  }

  post {
    always {
      archiveArtifacts artifacts: 'easyflow/.next/**', allowEmptyArchive: true
    }
  }
}