pipeline {
  agent any
  environment {
    IMAGE_NAME = "easyflow-frontend:${env.BUILD_NUMBER}"
  }

  stages {

    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install & Test & Build (node)') {
      agent {
        docker {
          image 'node:18' 
          args '-u root:root -e BASE_API=${BASE_API}'
        }
      }
      steps {
        dir('easyflow') {
          sh '''
             echo "=== SETUP SCHEMA FROM BACKEND ==="
             mkdir -p prisma
             cp ../backend/prisma/schema.prisma ./prisma/schema.prisma

             echo "=== CLEAN & INSTALL ==="
             rm -rf node_modules
             rm -rf .prisma
             rm -rf node_modules/.prisma
             rm -f package-lock.json
             
             # ติดตั้ง dependencies ใหม่
             npm install
             
             echo "=== GENERATE & BUILD ==="
             
             # --- แก้ไข V7: ใช้ NODE_OPTIONS (ไม้ตาย) ---
             
             # 1. ตั้งค่า Engine เป็น Binary (เสถียรสุดใน Docker)
             export PRISMA_CLI_QUERY_ENGINE_TYPE=binary
             export PRISMA_CLIENT_ENGINE_TYPE=binary
             
             # 2. ขยายเพดาน OS (เหมือนเดิม)
             ulimit -s 65535 || echo "Warning: Could not set ulimit"
             
             # 3. *** จุดสำคัญ *** # ใช้ NODE_OPTIONS เพื่อบังคับ Stack Size 10MB ไปยัง "ทุก Process" 
             # (ทั้งตัวแม่และตัวลูกที่ Prisma สร้างขึ้นมา)
             export NODE_OPTIONS="--stack-size=10240"
             
             # 4. รันคำสั่งปกติ (ไม่ต้องใส่ flag แล้ว เพราะมันอยู่ใน NODE_OPTIONS)
             npx prisma generate
             
             # -----------------------------------------------------

             npm test || true
             
             echo "Checking BASE_API: $BASE_API"
             npm run build
          '''
        }
      }
    }
    
    stage('Build Docker Image') {
      steps {
        sh '''
          docker build \
            -t easyflow-frontend:${BUILD_NUMBER} \
            -f easyflow/Dockerfile \
            .
          docker tag easyflow-frontend:${BUILD_NUMBER} easyflow-frontend:latest
        '''
      }
    }

    stage('Deploy (local docker)') {
          steps {
            sh """
              docker stop easyflow-frontend || true
              docker rm easyflow-frontend || true
              
              docker run -d \\
                --name easyflow-frontend \\
                -p 3000:3000 \\
                --link postgres-db:postgres \\
                --link easyflow-backend:backend \\
                -e DATABASE_URL="postgresql://postgres:root@postgres:5432/postgres" \\
                -e BASE_API="http://easyflow-backend:9000" \\
                -e NEXTAUTH_URL="http://localhost:3000" \\
                -e NEXTAUTH_SECRET="change-me-to-secure-random-string" \\
                -e SERVER_HOST="0.0.0.0" \\
                -e GOOGLE_CLIENT_ID="your-real-id-or-leave-empty-if-not-used" \\
                -e GOOGLE_CLIENT_SECRET="your-real-secret-or-leave-empty-if-not-used" \\
                easyflow-frontend:latest
            """
          }
      }
  }

  post {
    always {
      archiveArtifacts artifacts: 'easyflow/.next/**', allowEmptyArchive: true
      cleanWs() 
    }
  }
}